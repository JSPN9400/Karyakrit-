# Karyakrit Configuration

# Enable AI features (true/false)
KARYAKRIT_ENABLE_AI=true

# Provider orders (comma-separated). Tried in order; first one that's
# configured and succeeds wins. "fallback" is the deterministic, no-AI
# template generator and should usually stay last.
KARYAKRIT_ONLINE_PROVIDER_ORDER=gemini,grok,openai,deepseek,anthropic,groq,openrouter,fallback
KARYAKRIT_OFFLINE_PROVIDER_ORDER=ollama,fallback

# API Keys (optional - if not set, that provider is skipped automatically)
GEMINI_API_KEY=your_gemini_api_key_here
XAI_API_KEY=your_xai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Free-tier notes (check each provider's site for current limits/terms):
# - Groq (groq.com) currently offers a free tier with very fast inference.
#   Not the same company as xAI's Grok - both are supported separately above.
# - OpenRouter (openrouter.ai) is a gateway to many models from one API key;
#   some models there are free (e.g. "meta-llama/llama-3.1-8b-instruct:free").
# - Gemini and Groq have historically had generous free tiers; check current
#   terms before relying on them.

# Optional: override default model per provider
# GEMINI_MODEL=gemini-2.0-flash
# XAI_MODEL=grok-2-latest
# OPENAI_MODEL=gpt-4o-mini
# DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Ollama Configuration (free, fully local, no API key needed)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# NLU Provider (optional)
KARYAKRIT_AI_PROVIDER=fallback
