# Karyakrit Configuration

# Enable AI features (true/false)
KARYAKRIT_ENABLE_AI=true

# Provider orders (comma-separated)
KARYAKRIT_ONLINE_PROVIDER_ORDER=gemini,grok,openai,deepseek,fallback
KARYAKRIT_OFFLINE_PROVIDER_ORDER=ollama,fallback

# API Keys (optional - if not set, provider will be skipped)
GEMINI_API_KEY=your_gemini_api_key_here
XAI_API_KEY=your_xai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Ollama Configuration (for offline mode)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# NLU Provider (optional)
KARYAKRIT_AI_PROVIDER=fallback
